# Claude API
ANTHROPIC_API_KEY=sk-ant-...

# Email (Resend)
RESEND_API_KEY=re_...
REPORT_RECIPIENT=team@lab-2-scale.com
REPORT_FROM=reports@lab-2-scale.com
# Optional CC list — comma- or semicolon-separated. Change anytime (e.g. in the
# Railway dashboard) to update who's copied, no redeploy needed.
# Example: REPORT_CC=alice@lab-2-scale.com, bob@partner.com
REPORT_CC=

# Database
DATABASE_URL=sqlite:///data/lab2scale.db
# For production: postgresql://user:pass@host:5432/lab2scale

# Google Sheet leads tracker (optional) — each run appends candidate companies
# as leads to your sheet, deduped. Needs a service account (see lib/sheets_writer.py):
#   1) enable the Google Sheets API, 2) create a service account + JSON key,
#   3) share the sheet with the service account email (Editor).
GOOGLE_SERVICE_ACCOUNT_JSON=   # paste the entire service-account JSON here (one line)
LEADS_SHEET_ID=                # the id in your sheet URL: docs.google.com/spreadsheets/d/<ID>/edit
LEADS_SHEET_TAB=Leads          # optional; the tab to append to (default "Leads")

# Optional APIs
TAVILY_API_KEY=tvly-...       # Web search, powers BOTH System 1 (research deal flow) and
                              # System 2 (events). Free tier: 1000 searches/month — note a daily
                              # sweep uses ~25 (10 research + 15 events), ≈ 750/month.
                              # Get a key at https://tavily.com. Without it, research falls back to
                              # RSS only and events are skipped.

# Research (System 1) tuning — all optional, sensible defaults in code:
RESEARCH_WINDOW_DAYS=7        # RSS look-back in days. 7 = the full week before each Monday run.
                              #   (Use 1 for daily cadence so consecutive runs don't overlap.)
RESEARCH_SEARCH_THRESHOLD=6.0 # Keep-threshold for the web-search path (RSS stays strict at 8.0).
RESEARCH_SEARCH_TIME_RANGE=week  # Tavily recency for research search: day | week | month.
EVENTBRITE_API_KEY=           # For event tracking — required if any config uses method: eventbrite
MEETUP_API_KEY=               # For Meetup events
CRUNCHBASE_API_KEY=           # For startup tracking (paid)

# Scheduling
RUN_SCHEDULE=3x_daily         # 3x_daily | daily | weekly
REPORT_DAY=monday             # Day of week for weekly report
REPORT_TIME=09:00             # ET

# Logging
LOG_LEVEL=INFO
